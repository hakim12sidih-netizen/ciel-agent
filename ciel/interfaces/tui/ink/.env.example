# CIEL TUI — Environment Configuration
# Copy to .env and adjust

# Python interpreter for the gateway backend
CIEL_PYTHON=python3

# Working directory for CIEL (must contain ciel/ package)
CIEL_CWD=/home/sidi/ciel

# Deno executable (optional, for gateway client)
# CIEL_DENO=deno

# Debug logging (uncomment to enable)
# DEBUG=ciel:gateway,ciel:tui
